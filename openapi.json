{
  "openapi": "3.0.0",
  "info": {
    "title": "Partner Payments API",
    "version": "1.0.0",
    "description": "Server-to-server REST API for vetted partners (government agency case systems, SaaS billing platforms) to drive payment operations without a citizen-facing browser flow.\n\n## Authentication\n\nAll payment endpoints require one of:\n\n- **ApiKey** — `Authorization: ApiKey pc_<your-key>` (issued by GroGov admin)\n- **Bearer JWT** — exchange your API key once via `POST /api/partner/v1/auth/token`, then use the returned JWT as `Authorization: Bearer <token>`\n\n## Amounts\n\nAll monetary amounts in the API are in **minor units (cents)**. `100` = $1.00 USD.\n\nThe `currency` field is always `USD` in v1.\n\n## Idempotency\n\nFor `POST /payments` and `POST /payments/:id/refund`, pass an `Idempotency-Key` header (any unique string, max 255 chars). Replayed requests return the cached response with `Idempotent-Replayed: true` header. Using the same key with a different request body returns `409`.\n\n## Error Codes\n\n| Code | HTTP | Meaning |\n|---|---|---|\n| `PAYMENT_DECLINED` | 402 | Gateway declined the charge |\n| `PAYMENT_TIMEOUT` | 504 | Gateway did not respond in time |\n| `PAYMENT_GATEWAY_ERROR` | 502 | Unexpected gateway error |\n| `PAYMENT_NOT_FOUND` | 404 | Payment ID not found or out of scope |\n| `INVALID_STATE` | 422 | Payment is in the wrong state for this operation |\n| `REFUND_EXCEEDS_AMOUNT` | 422 | Refund amount exceeds remaining balance |\n| `CAPTURE_FAILED` | 422 | Gateway rejected the capture |\n| `VOID_FAILED` | 422 | Gateway rejected the void (use refund instead) |\n| `IDEMPOTENCY_MISMATCH` | 409 | Same Idempotency-Key with different body |\n| `GATEWAY_NOT_CONFIGURED` | 503 | Portal has no payment gateway set up |\n| `PORTAL_ACCESS_DENIED` | 403 | Partner is not authorised for this portal |\n",
    "contact": {
      "name": "GroGov Partner Support",
      "email": "support@grogov.us"
    }
  },
  "servers": [
    {
      "url": "https://apistagepc.grogov.us",
      "description": "Staging"
    }
  ],
  "security": [
    { "ApiKeyAuth": [] },
    { "BearerAuth": [] }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Exchange an API key for a short-lived JWT to avoid per-request bcrypt overhead."
    },
    {
      "name": "Payments",
      "description": "Create and manage payment groups with optional line-item granularity."
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Pass your API key directly: `pc_<your-key>`. The `ApiKey ` scheme prefix is also accepted: `ApiKey pc_<your-key>`."
      },
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT obtained from `POST /api/partner/v1/auth/token`"
      }
    },
    "schemas": {
      "PayerInfo": {
        "type": "object",
        "properties": {
          "firstName": { "type": "string", "example": "Jane" },
          "lastName": { "type": "string", "example": "Doe" },
          "email": { "type": "string", "format": "email", "example": "jane.doe@example.com" },
          "phone": { "type": "string", "example": "+15551234567" },
          "address": {
            "type": "object",
            "properties": {
              "line1": { "type": "string" },
              "line2": { "type": "string" },
              "city": { "type": "string" },
              "state": { "type": "string" },
              "zip": { "type": "string" },
              "country": { "type": "string", "default": "US" }
            }
          }
        }
      },
      "LineItemInput": {
        "type": "object",
        "required": ["amount", "referenceId"],
        "properties": {
          "amount": {
            "type": "integer",
            "description": "Amount in cents.",
            "example": 5000
          },
          "referenceId": {
            "type": "string",
            "description": "Your internal case/invoice ID.",
            "example": "CASE-2024-00123"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "example": "Court filing fee"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true,
            "description": "Arbitrary key-value pairs stored with the line item.",
            "example": { "docketNumber": "24-CV-001" }
          }
        }
      },
      "PaymentMethodCardToken": {
        "type": "object",
        "required": ["type", "token"],
        "properties": {
          "type": { "type": "string", "enum": ["card_token"], "example": "card_token" },
          "token": {
            "type": "string",
            "description": "One-time tokenized card from NMI Collect.js.",
            "example": "tok_abc123"
          }
        }
      },
      "PaymentMethodVault": {
        "type": "object",
        "required": ["type", "vaultId"],
        "properties": {
          "type": { "type": "string", "enum": ["vault"], "example": "vault" },
          "vaultId": {
            "type": "string",
            "description": "Stored card vault ID from a previous transaction.",
            "example": "vault_xyz789"
          }
        }
      },
      "CreatePaymentRequest": {
        "type": "object",
        "required": ["portalId", "amount", "currency", "paymentMethod", "lineItems"],
        "properties": {
          "portalId": {
            "type": "string",
            "format": "uuid",
            "description": "The payment portal to process against.",
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "amount": {
            "type": "integer",
            "description": "Total amount in cents. Must equal sum of line item amounts.",
            "example": 10000
          },
          "currency": {
            "type": "string",
            "enum": ["USD"],
            "default": "USD"
          },
          "capture": {
            "type": "string",
            "enum": ["sale", "auth"],
            "default": "sale",
            "description": "`sale` charges immediately. `auth` places a hold; use `POST /:id/capture` to settle. (The response echoes this back as `captureMode`.)"
          },
          "paymentMethod": {
            "oneOf": [
              { "$ref": "#/components/schemas/PaymentMethodCardToken" },
              { "$ref": "#/components/schemas/PaymentMethodVault" }
            ],
            "discriminator": {
              "propertyName": "type",
              "mapping": {
                "card_token": "#/components/schemas/PaymentMethodCardToken",
                "vault": "#/components/schemas/PaymentMethodVault"
              }
            }
          },
          "lineItems": {
            "type": "array",
            "minItems": 1,
            "maxItems": 50,
            "items": { "$ref": "#/components/schemas/LineItemInput" }
          },
          "payer": { "$ref": "#/components/schemas/PayerInfo" },
          "orderDescription": {
            "type": "string",
            "maxLength": 255,
            "example": "Court payment for case 2024-00123"
          }
        }
      },
      "CapturePaymentRequest": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "integer",
            "description": "Amount to capture in cents. Defaults to the full authorized amount if omitted.",
            "example": 10000
          }
        }
      },
      "RefundPaymentRequest": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "integer",
            "description": "Amount to refund in cents. Defaults to the full remaining amount if omitted.",
            "example": 5000
          },
          "reason": {
            "type": "string",
            "maxLength": 500,
            "example": "Case dismissed"
          }
        }
      },
      "VoidPaymentRequest": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string",
            "maxLength": 500,
            "example": "Duplicate submission"
          }
        }
      },
      "LineItemResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid", "description": "Line item ID" },
          "amount": { "type": "integer", "description": "Cents", "example": 5000 },
          "serviceFee": { "type": "integer", "description": "Pro-rated service fee in cents", "example": 150 },
          "status": { "type": "string", "example": "succeeded" },
          "refundedAmount": { "type": "integer", "description": "Cents refunded so far", "example": 0 },
          "remainingRefundableAmount": { "type": "integer", "description": "Cents still refundable", "example": 5000 },
          "referenceId": { "type": "string", "example": "CASE-2024-00123" },
          "description": { "type": "string", "example": "Court filing fee" },
          "metadata": { "type": "object", "additionalProperties": true }
        }
      },
      "GatewayInfo": {
        "type": "object",
        "properties": {
          "transactionId": { "type": "string", "description": "NMI gateway transaction ID", "example": "4938271649" },
          "authCode": { "type": "string", "description": "Gateway authorization code", "example": "123456" }
        }
      },
      "PaymentGroupResponse": {
        "type": "object",
        "properties": {
          "transactionId": { "type": "string", "format": "uuid", "description": "Payment group ID" },
          "status": {
            "type": "string",
            "enum": ["pending", "authorized", "succeeded", "failed", "voided", "refunded", "partially_refunded", "unknown"],
            "example": "succeeded"
          },
          "captureMode": { "type": "string", "enum": ["sale", "auth"] },
          "currency": { "type": "string", "example": "USD" },
          "amount": { "type": "integer", "description": "Base amount in cents (excluding service fee)", "example": 10000 },
          "serviceFee": { "type": "integer", "description": "Service fee in cents", "example": 300 },
          "totalCharged": { "type": "integer", "description": "Amount + service fee in cents", "example": 10300 },
          "refundedAmount": { "type": "integer", "description": "Total refunded in cents", "example": 0 },
          "remainingRefundableAmount": { "type": "integer", "description": "Cents still refundable", "example": 10300 },
          "authorizedAmount": { "type": "integer", "description": "Auth hold amount in cents (auth mode only)", "example": 10300 },
          "capturedAmount": { "type": "integer", "description": "Captured amount in cents", "example": 0 },
          "confirmationNumber": { "type": "string", "example": "PP-1710000000000" },
          "portalId": { "type": "string", "format": "uuid" },
          "payer": { "$ref": "#/components/schemas/PayerInfo" },
          "paymentMethod": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "example": "card" },
              "brand": { "type": "string", "example": "visa" },
              "last4": { "type": "string", "example": "4242" },
              "expMonth": { "type": "integer", "example": 12 },
              "expYear": { "type": "integer", "example": 2027 }
            }
          },
          "gateway": { "$ref": "#/components/schemas/GatewayInfo" },
          "lineItems": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/LineItemResponse" }
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "description": "Auth expiry timestamp (auth mode only)"
          },
          "capturedAt": { "type": "string", "format": "date-time" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "RefundGroupResponse": {
        "type": "object",
        "description": "Returned when refunding by group ID.",
        "properties": {
          "transactionId": { "type": "string", "format": "uuid", "description": "Payment group ID" },
          "target": { "type": "string", "enum": ["group"] },
          "reversalType": { "type": "string", "enum": ["void", "refund"], "description": "`void` when the batch was still open; `refund` otherwise." },
          "amount": { "type": "integer", "description": "Refunded amount in cents", "example": 5000 },
          "currency": { "type": "string", "example": "USD" },
          "reason": { "type": "string", "nullable": true, "example": "Case dismissed" },
          "status": { "type": "string", "enum": ["succeeded"] },
          "remainingRefundableAmount": { "type": "integer", "description": "Cents still refundable after this operation", "example": 5300 },
          "gateway": { "$ref": "#/components/schemas/GatewayInfo" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "RefundLineItemResponse": {
        "type": "object",
        "description": "Returned when refunding by line item ID.",
        "properties": {
          "transactionId": { "type": "string", "format": "uuid", "description": "Parent payment group ID" },
          "target": { "type": "string", "enum": ["line_item"] },
          "targetId": { "type": "string", "format": "uuid", "description": "The line item that was refunded" },
          "reversalType": { "type": "string", "enum": ["void", "refund"] },
          "amount": { "type": "integer", "description": "Refunded line item amount in cents", "example": 5000 },
          "refundedServiceFee": { "type": "integer", "description": "Pro-rated service fee refunded in cents", "example": 150 },
          "currency": { "type": "string", "example": "USD" },
          "reason": { "type": "string", "nullable": true, "example": "Case dismissed" },
          "status": { "type": "string", "enum": ["succeeded"] },
          "lineItemRemainingRefundableAmount": { "type": "integer", "description": "Cents still refundable on this line item", "example": 0 },
          "groupRemainingRefundableAmount": { "type": "integer", "description": "Cents still refundable on the parent group", "example": 4850 },
          "gateway": { "$ref": "#/components/schemas/GatewayInfo" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "VoidedLineItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid", "description": "Line item ID" },
          "amount": { "type": "integer", "description": "Voided amount in cents", "example": 5000 }
        }
      },
      "VoidResponse": {
        "type": "object",
        "properties": {
          "transactionId": { "type": "string", "format": "uuid", "description": "Payment group ID that was voided" },
          "amount": { "type": "integer", "description": "Total voided amount in cents", "example": 10300 },
          "currency": { "type": "string", "example": "USD" },
          "reason": { "type": "string", "nullable": true, "example": "Duplicate submission" },
          "status": { "type": "string", "enum": ["succeeded"] },
          "voidedLineItems": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/VoidedLineItem" }
          },
          "voidedServiceFee": { "type": "integer", "description": "Service fee voided in cents", "example": 300 },
          "gateway": { "$ref": "#/components/schemas/GatewayInfo" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "type": "object" },
          "message": { "type": "string" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "message": { "type": "string", "example": "Payment was declined." },
          "details": {
            "type": "object",
            "required": ["code"],
            "properties": {
              "code": { "type": "string", "example": "PAYMENT_DECLINED" },
              "transactionId": {
                "type": "string",
                "format": "uuid",
                "description": "Present when a transaction was created before the error occurred (e.g. `PAYMENT_DECLINED`, `PAYMENT_TIMEOUT`)."
              },
              "gatewayMessage": { "type": "string", "description": "Raw gateway response message" },
              "gatewayResponseCode": { "type": "string", "description": "Raw gateway response code" }
            }
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": {
            "type": "object",
            "properties": {
              "accessToken": { "type": "string" },
              "tokenType": { "type": "string", "example": "Bearer" },
              "expiresIn": { "type": "integer", "example": 3600 },
              "issuedAt": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    }
  },
  "paths": {
    "/api/partner/v1/auth/token": {
      "post": {
        "tags": ["Auth"],
        "summary": "Exchange API key for JWT",
        "description": "Authenticates with an `ApiKey` and returns a short-lived JWT (1 hour). Use the JWT as `Authorization: Bearer <token>` on subsequent requests to avoid per-request bcrypt overhead.",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "JWT issued successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenResponse" }
              }
            }
          },
          "401": {
            "description": "Invalid or revoked API key",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/partner/v1/payments": {
      "post": {
        "tags": ["Payments"],
        "summary": "Create a payment",
        "description": "Charge a card token or vault entry for one or more line items. Use `capture: 'auth'` to place an authorization hold and capture later.\n\nSupports idempotency via the `Idempotency-Key` header.",
        "parameters": [
          {
            "in": "header",
            "name": "Idempotency-Key",
            "schema": { "type": "string", "maxLength": 255 },
            "required": false,
            "description": "Unique key to prevent duplicate charges on retry."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreatePaymentRequest" },
              "examples": {
                "sale_card_token": {
                  "summary": "Immediate sale with card token",
                  "value": {
                    "portalId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                    "amount": 10000,
                    "currency": "USD",
                    "capture": "sale",
                    "paymentMethod": {
                      "type": "card_token",
                      "token": "tok_abc123"
                    },
                    "payer": {
                      "firstName": "Jane",
                      "lastName": "Doe",
                      "email": "jane.doe@example.com"
                    },
                    "lineItems": [
                      {
                        "amount": 7500,
                        "referenceId": "CASE-2024-001",
                        "description": "Court filing fee"
                      },
                      {
                        "amount": 2500,
                        "referenceId": "CASE-2024-002",
                        "description": "Processing fee"
                      }
                    ]
                  }
                },
                "auth_vault": {
                  "summary": "Auth hold with vault ID",
                  "value": {
                    "portalId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                    "amount": 5000,
                    "currency": "USD",
                    "capture": "auth",
                    "paymentMethod": {
                      "type": "vault",
                      "vaultId": "vault_xyz789"
                    },
                    "lineItems": [
                      {
                        "amount": 5000,
                        "referenceId": "INV-0042"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment created",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessResponse" },
                    {
                      "properties": {
                        "data": { "$ref": "#/components/schemas/PaymentGroupResponse" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "402": {
            "description": "Payment declined by gateway",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "409": {
            "description": "Idempotency key reused with different body",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "504": {
            "description": "Gateway timeout — payment status unknown",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Payments"],
        "summary": "List payments",
        "description": "Returns a cursor-paginated list of payments for your partner account, newest first.",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 25 },
            "description": "Number of results per page."
          },
          {
            "in": "query",
            "name": "cursor",
            "schema": { "type": "string" },
            "description": "Opaque cursor from the previous page's `nextCursor` field."
          },
          {
            "in": "query",
            "name": "status",
            "schema": {
              "type": "string",
              "enum": ["pending", "authorized", "succeeded", "failed", "voided", "refunded", "partially_refunded", "unknown"]
            }
          },
          {
            "in": "query",
            "name": "portalId",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "in": "query",
            "name": "referenceId",
            "schema": { "type": "string" },
            "description": "Filters to groups that have at least one line item with this reference ID."
          },
          {
            "in": "query",
            "name": "from",
            "schema": { "type": "string", "format": "date-time" },
            "description": "Filter by `createdAt >= from`."
          },
          {
            "in": "query",
            "name": "to",
            "schema": { "type": "string", "format": "date-time" },
            "description": "Filter by `createdAt <= to`."
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of payments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/PaymentGroupResponse" }
                    },
                    "pagination": {
                      "type": "object",
                      "properties": {
                        "nextCursor": { "type": "string", "nullable": true },
                        "hasMore": { "type": "boolean" },
                        "limit": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/partner/v1/payments/{id}": {
      "get": {
        "tags": ["Payments"],
        "summary": "Get a payment",
        "description": "Retrieve a payment group by its ID. You can also pass a **line item ID** — the response will include the full group with `lookedUpBy.type: 'item'` to indicate it was resolved via a line item.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "description": "Payment group ID or line item ID."
          }
        ],
        "responses": {
          "200": {
            "description": "Payment found",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessResponse" },
                    {
                      "properties": {
                        "data": {
                          "allOf": [
                            { "$ref": "#/components/schemas/PaymentGroupResponse" },
                            {
                              "properties": {
                                "lookedUpBy": {
                                  "type": "object",
                                  "properties": {
                                    "type": { "type": "string", "enum": ["group", "item"] },
                                    "id": { "type": "string", "format": "uuid" }
                                  }
                                }
                              }
                            }
                          ]
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Payment not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/partner/v1/payments/{id}/capture": {
      "post": {
        "tags": ["Payments"],
        "summary": "Capture an authorized payment",
        "description": "Settles an `authorized` payment. Only valid when `status` is `authorized` and `captureMode` is `auth`.\n\nPartial captures (by specifying `amount`) are supported but the remaining unheld amount is released — a second capture is not possible.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "description": "Payment group ID."
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CapturePaymentRequest" },
              "example": { "amount": 10000 }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment captured",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessResponse" },
                    {
                      "properties": {
                        "data": { "$ref": "#/components/schemas/PaymentGroupResponse" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "422": {
            "description": "Payment is not in `authorized` state or gateway rejected the capture",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/partner/v1/payments/{id}/refund": {
      "post": {
        "tags": ["Payments"],
        "summary": "Refund a payment",
        "description": "Refunds a succeeded payment. Pass a **group ID** to refund the entire payment (or a partial amount). Pass a **line item ID** to target a specific line item — the refund amount is capped at that item's remaining balance.\n\nService fees are pro-rated on partial refunds. The system tries a void first; if the batch is already closed, it falls back to a refund transaction.\n\nSupports idempotency via the `Idempotency-Key` header.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "description": "Payment group ID or line item ID."
          },
          {
            "in": "header",
            "name": "Idempotency-Key",
            "schema": { "type": "string", "maxLength": 255 },
            "required": false
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RefundPaymentRequest" },
              "examples": {
                "full_refund": {
                  "summary": "Full refund",
                  "value": { "reason": "Case dismissed" }
                },
                "partial_refund": {
                  "summary": "Partial refund",
                  "value": { "amount": 5000, "reason": "Partial fee waiver" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Refund processed. Shape depends on whether a group ID or line item ID was passed.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessResponse" },
                    {
                      "properties": {
                        "data": {
                          "oneOf": [
                            { "$ref": "#/components/schemas/RefundGroupResponse" },
                            { "$ref": "#/components/schemas/RefundLineItemResponse" }
                          ],
                          "discriminator": {
                            "propertyName": "target",
                            "mapping": {
                              "group": "#/components/schemas/RefundGroupResponse",
                              "line_item": "#/components/schemas/RefundLineItemResponse"
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                "examples": {
                  "group_refund": {
                    "summary": "Group refund",
                    "value": {
                      "success": true,
                      "data": {
                        "transactionId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                        "target": "group",
                        "reversalType": "refund",
                        "amount": 10300,
                        "currency": "USD",
                        "reason": "Case dismissed",
                        "status": "succeeded",
                        "remainingRefundableAmount": 0,
                        "gateway": { "transactionId": "4938271649" },
                        "createdAt": "2024-03-01T12:00:00.000Z"
                      }
                    }
                  },
                  "line_item_refund": {
                    "summary": "Line item refund",
                    "value": {
                      "success": true,
                      "data": {
                        "transactionId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                        "target": "line_item",
                        "targetId": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
                        "reversalType": "void",
                        "amount": 5000,
                        "refundedServiceFee": 150,
                        "currency": "USD",
                        "reason": null,
                        "status": "succeeded",
                        "lineItemRemainingRefundableAmount": 0,
                        "groupRemainingRefundableAmount": 5150,
                        "gateway": { "transactionId": "4938271650" },
                        "createdAt": "2024-03-01T12:00:00.000Z"
                      }
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Refund amount exceeds remaining balance or invalid state",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/partner/v1/payments/{id}/void": {
      "post": {
        "tags": ["Payments"],
        "summary": "Void a payment",
        "description": "Cancels a payment at the gateway level. **Strict** — if the gateway rejects the void (e.g. batch already closed), this returns `422 VOID_FAILED` and does **not** fall back to a refund. Use `POST /:id/refund` instead once a batch has closed.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "description": "Payment group ID."
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/VoidPaymentRequest" },
              "example": { "reason": "Duplicate submission" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment voided",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessResponse" },
                    {
                      "properties": {
                        "data": { "$ref": "#/components/schemas/VoidResponse" }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "transactionId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                    "amount": 10300,
                    "currency": "USD",
                    "reason": "Duplicate submission",
                    "status": "succeeded",
                    "voidedLineItems": [
                      { "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901", "amount": 7500 },
                      { "id": "c3d4e5f6-a7b8-9012-cdef-123456789012", "amount": 2500 }
                    ],
                    "voidedServiceFee": 300,
                    "gateway": { "transactionId": "4938271649" },
                    "createdAt": "2024-03-01T12:00:00.000Z"
                  }
                }
              }
            }
          },
          "422": {
            "description": "Gateway rejected the void. Use `POST /:id/refund` instead.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ErrorResponse" },
                    {
                      "properties": {
                        "details": {
                          "properties": {
                            "suggestedAction": { "type": "string", "example": "refund" }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
