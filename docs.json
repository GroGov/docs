{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "GroGov Payments API",
  "colors": {
    "primary": "#1F6FEB",
    "light": "#4D9BFF",
    "dark": "#1F6FEB"
  },
  "favicon": "/assets/images/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "guides/introduction",
              "guides/quickstart",
              "guides/authentication"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "guides/payment-lifecycle",
              "guides/refunds-and-line-items",
              "guides/idempotency",
              "guides/amounts-fees-pagination",
              "guides/errors"
            ]
          },
          {
            "group": "Testing",
            "pages": [
              "guides/sandbox-and-test-cases"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.json"
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@grogov.us"
      },
      {
        "label": "Dashboard",
        "href": "https://pc.grogov.us"
      }
    ]
  },
  "footer": {
    "socials": {
      "website": "https://grogov.us"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ],
    "display": "header"
  },
  "markdown": {
    "schema": true
  },
  "appearance": {
    "default": "light"
  }
}
